<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        *{
          margin: 0;  
          padding: 0;
          box-sizing: border-box;
        }
        .main-Box{
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 15%;
        }
        .main-Box .box form{
            width: 300px;
            height: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
            border: 1px solid #333;
            border-radius: 5px;
            padding: 18px;
        }
        .box h4{
            text-align: center;
            font-size: 22px;
            margin-bottom: 12px;
        }
        .box input{
            height: 40px;
            padding: 5px;
        }
        .box button{
            height: 30px;
            margin-top: 15px;
            font-size: 17px;
        }
        .box p{
            text-align: center;
        }
        a{
            text-decoration: none;
        }
    </style>
</head>
<body>
   <div class="main-Box">
        <div class="box">
            <form action="/createAccount">
                <h4>Create an Account</h4>
                UserName: <input type="text" placeholder="UserName" name="UserName">
                Email: <input type="email" placeholder="Email" name="Email">
                Password: <input type="password" placeholder="Password" name="Password">
                <button type="submit">Register</button>
                <p>Already have an account ? <b><a href="/signIn">Sign in</a></b></p>
            </form>
        </div>
    </div>
</body>
</html>